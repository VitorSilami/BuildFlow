# Copie para .env e preencha com valores reais. Nunca commite o .env real.

# --- Backend (Django) ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=changeme-generate-a-real-secret-key
DJANGO_DEBUG=True
DATABASE_URL=postgres://buildflow:buildflow@localhost:5432/buildflow

# Google OAuth (Google Cloud Console > Credentials > OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
